<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — DDV Blog</title>
  <meta name="description" content="{{ description or title }}">
  <link rel="canonical" href="https://digitallydemented.com{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or title }}">
  <meta property="og:url" content="https://digitallydemented.com{{ page.url }}">
  <meta property="og:type" content="article">
  <meta property="og:image" content="https://digitallydemented.com/images/og-social-card.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="Digitally Demented Ventures">
  <meta property="og:locale" content="en_US">
  <meta name="author" content="Daniel Walters">
  <meta property="article:published_time" content="{{ date | shortDate }}">
  <meta property="article:author" content="https://digitallydemented.com/about">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@DigitalDemented">
  <meta name="twitter:creator" content="@DigitalDemented">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description or title }}">
  <meta name="twitter:image" content="https://digitallydemented.com/images/og-social-card.png">

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">

  <!-- Fonts (same as main site) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet">

  <!-- Main site styles + blog styles -->
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/blog.css">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LNDZRGMG0D"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LNDZRGMG0D');
  </script>

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ description or title }}",
    "datePublished": "{{ date | shortDate }}",
    "dateModified": "{{ date | shortDate }}",
    "author": {
      "@type": "Person",
      "name": "Daniel Walters",
      "url": "https://digitallydemented.com/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Digitally Demented Ventures",
      "url": "https://digitallydemented.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://digitallydemented.com/images/ddv-logo-square.png"
      }
    },
    "url": "https://digitallydemented.com{{ page.url }}",
    "image": "https://digitallydemented.com/images/og-social-card.png",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://digitallydemented.com{{ page.url }}"
    }
  }
  </script>
</head>
<body>
  <header class="blog-header">
    <nav class="blog-nav">
      <a href="/" class="blog-logo">
        <img src="/images/ddv-logo-bug-nav.png" alt="DDV" width="40" height="40">
      </a>
      <a href="/about">About Me</a>
      <a href="/courses">Course</a>
      <a href="/consulting">Consulting</a>
      <a href="/tools">Tools I Use</a>
      <a href="/blog/">Blog</a>
      <a href="/contact">Contact</a>
    </nav>
  </header>

  <main class="blog-content">
    <article class="blog-post">
      <div class="post-meta">
        <time datetime="{{ date | shortDate }}">{{ date | readableDate }}</time>
      </div>

      <h1>{{ title }}</h1>

      <div class="post-body">
        {{ content | safe }}
      </div>
    </article>

    <div class="post-footer">
      <a href="/blog/">&larr; Back to all posts</a>
    </div>
  </main>

  <footer class="blog-footer">
    <p>&copy; {{ "now" | currentYear }} Digitally Demented Ventures LLC</p>
  </footer>
</body>
</html>
